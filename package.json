{
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "db:generate": "dotenv -e apps/web/.env.local -- pnpm -C packages/db db:generate",
    "db:push": "dotenv -e apps/web/.env.local -- pnpm -C packages/db db:push",
    "db:migrate": "pnpm -C packages/db db:migrate",
    "db:studio": "dotenv -e apps/web/.env.local -- pnpm -C packages/db db:studio"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.1.1",
    "rimraf": "^6.0.1",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "name": "with-react-native-web",
  "packageManager": "pnpm@10.21.0"
}